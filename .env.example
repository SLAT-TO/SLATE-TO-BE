DB_URL=jdbc:mysql://<host>:3306/<database>?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USER=<username>
DB_PASSWORD=<password>
JPA_DDL_AUTO=validate

# JWT 서명 키 (최소 32바이트 이상의 랜덤 문자열)
JWT_SECRET=<jwt-secret>

# 구글 OAuth (https://console.cloud.google.com 에서 발급)
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback/google

# 로그인 완료 후 돌아갈 프론트엔드 주소
FRONTEND_BASE_URL=http://localhost:3000
